<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Gesture Layer for full screen interaction -->
    <View
        android:id="@+id/gesture_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <include
        android:id="@+id/double_tap_overlay"
        layout="@layout/player_double_tap_overlay" />

    <include
        android:id="@+id/loading_overlay"
        layout="@layout/player_loading_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main Overlay Controls -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            android:id="@+id/top_bar_layout"
            layout="@layout/player_top_bar"
            app:layout_constraintTop_toTopOf="parent" />

        <include
            android:id="@+id/center_controls_layout"
            layout="@layout/player_center_controls"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <include
            android:id="@+id/bottom_bar_layout"
            layout="@layout/player_bottom_bar"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Lock Button -->
        <ImageButton
            android:id="@+id/btn_lock"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/glass_background"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_lock_lock"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:tint="@color/text_primary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/settings_panel_layout"
        layout="@layout/player_settings_panel"
        app:layout_constraintEnd_toEndOf="parent" />

    <include
        android:id="@+id/gesture_overlay_layout"
        layout="@layout/player_gesture_overlay"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
